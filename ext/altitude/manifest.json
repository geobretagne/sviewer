{
  "id":          "altitude",
  "type":        "extension",
  "version":     "2.0.0",
  "name":        "Altitude",
  "description": "Altitude ponctuelle et profil altimétrique via l'API IGN Géoplateforme. Deux modes : clic pour mesurer l'altitude d'un point, ou tracé d'un itinéraire pour obtenir un profil en long.",
  "author":      "fphg",
  "screenshot":  "screenshot.png",
  "tags":        ["altimétrie", "altitude", "profil", "dénivelé", "IGN", "Géoplateforme"],

  "entry": "extension.js",

  "sviewer": {
    "minVersion": "0.11.1"
  },

  "examples": [
    {
      "title": "Altitude — Chamonix",
      "url":   "?ext=altitude&z=12&x=6.8770&y=45.9237"
    },
    {
      "title": "Profil — Paris",
      "url":   "?ext=altitude&z=12&x=2.3488&y=48.8534"
    }
  ]
}
