{
  "name": "sviewer",
  "version": "0.2.0",
  "description": "geOrchestra simple mobile map viewer",
  "scripts": {
    "build:ol": "esbuild build/ol-custom-entry.js --bundle --minify --format=iife --outfile=build/ol-new.js",
    "minify": "npm run minify:js && npm run minify:embed && npm run minify:css",
    "minify:js": "terser js/sviewer.js -o js/sviewer.min.js -c -m",
    "minify:embed": "terser js/embed.js -o js/embed.min.js -c -m",
    "minify:css": "postcss css/sviewer.css -o css/sviewer.min.css",
    "build": "npm run build:ol && npm run minify",
    "stamp": "node -e \"const p=require('./package.json'),c=require('child_process').execSync('git rev-parse --short HEAD').toString().trim(),f=require('fs'),s=f.readFileSync('js/embed.js','utf8');f.writeFileSync('js/embed.js',s.replace(/var SVIEWER_VERSION='[^']*'/,'var SVIEWER_VERSION=\\''+p.version+'\\'').replace(/var SVIEWER_COMMIT='[^']*'/,'var SVIEWER_COMMIT=\\''+c+'\\''))\""
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "cssnano": "^6.1.2",
    "esbuild": "^0.20.0",
    "eslint": "^10.2.1",
    "eslint-plugin-security": "^4.0.0",
    "globals": "^17.5.0",
    "ol": "^9.1.0",
    "postcss-cli": "^11.0.1",
    "terser": "^5.31.0"
  },
  "keywords": [
    "map",
    "viewer",
    "mobile",
    "openlayers"
  ],
  "author": "geoBretagne",
  "license": "GPL-3.0-or-later"
}
