{
  "name": "sviewer",
  "version": "0.15.0",
  "description": "simple mobile map viewer",
  "scripts": {
    "build:ol": "esbuild build/ol-custom-entry.js --bundle --minify --format=iife --outfile=static/lib/ol/ol.js",
    "build:ol-dual": "esbuild build/ol-dual-entry.js --bundle --minify --format=iife --outfile=../dual/lib/ol/ol.js",
    "minify": "npm run minify:js && npm run minify:embed && npm run minify:css",
    "minify:js": "terser js/sviewer.js -o static/js/sviewer.min.js -c -m",
    "minify:embed": "terser js/embed.js -o static/js/embed.min.js -c -m",
    "minify:css": "postcss css/sviewer.css -o static/css/sviewer.min.css",
    "build": "npm run build:ol && npm run minify",
    "stamp": "node scripts/stamp.js",
    "lint:js": "eslint js/ static/js/",
    "lint:css": "stylelint css/sviewer.css",
    "lint": "npm run lint:js && npm run lint:css",
    "build:catalog": "node build/generate-catalog.js",
    "build:psv": "esbuild build/psv-entry.js --bundle --minify --format=iife --outfile=ext/panoramax/psv.min.js",
    "build:mvt": "esbuild build/mvt-entry.js --bundle --minify --format=iife --outfile=ext/panoramax/mvt.min.js"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@photo-sphere-viewer/core": "^5.14.1",
    "bootstrap-icons": "^1.13.1",
    "cssnano": "^6.1.2",
    "esbuild": "^0.20.0",
    "eslint": "^10.2.1",
    "eslint-plugin-security": "^4.0.0",
    "globals": "^17.5.0",
    "ol": "^9.1.0",
    "postcss-cli": "^11.0.1",
    "qr-creator": "^1.0.0",
    "stylelint": "^17.11.0",
    "stylelint-config-standard": "^40.0.0",
    "terser": "^5.31.0",
    "three": "^0.179.0"
  },
  "keywords": [
    "map",
    "viewer",
    "mobile",
    "openlayers"
  ],
  "author": "geoBretagne",
  "license": "GPL-3.0-or-later"
}
